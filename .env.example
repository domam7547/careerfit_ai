# .env.example
# 이 파일은 GitHub에 올려도 된다.
# 실제 Key는 절대 입력하지 말 것. 예시 형식만 보여준다.

GEMINI_API_KEY=your_gemini_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here 
HUGGINGFACE_TOKEN=your_huggingface_token_here
HUGGINGFACE_PROVIDER=featherless-ai
# 이전 예시 이름도 일부 코드에서 호환되지만, 새 설정은 HUGGINGFACE_TOKEN을 권장
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here
MOCK_MODE=false
LLM_MODEL=gemini-2.5-flash-lite 
# Hugging Face Qwen 테스트 예시
# LLM_MODEL=huggingface:Qwen/Qwen2.5-0.5B-Instruct
